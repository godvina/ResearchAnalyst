# Investigative Intelligence Platform — Environment Variables
# Copy this file to .env and fill in the values

# === Brave Search API (for OSINT Research Agent) ===
BRAVE_SEARCH_API_KEY=

# === AWS Account & Region ===
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1

# === Aurora PostgreSQL (set via Secrets Manager in production) ===
AURORA_PROXY_ENDPOINT=
AURORA_DB_NAME=research_analyst
AURORA_SECRET_ARN=
DB_PORT=5432

# === Neptune Graph Database ===
NEPTUNE_ENDPOINT=
NEPTUNE_PORT=8182

# === S3 Buckets ===
S3_DATA_BUCKET=
S3_BUCKET_NAME=

# === Bedrock AI Models ===
BEDROCK_LLM_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# === OpenSearch Serverless (optional, for enterprise tier) ===
OPENSEARCH_ENDPOINT=
OPENSEARCH_COLLECTION_ID=
OPENSEARCH_ENABLED=false

# === Lambda Function Name (for scripts that invoke Lambda) ===
LAMBDA_FUNCTION_NAME=

# === API Gateway ===
API_URL=

# === Feature Flags ===
ACCESS_CONTROL_ENABLED=false
NEPTUNE_ENABLED=true
REKOGNITION_ENABLED=true
